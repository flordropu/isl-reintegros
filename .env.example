# ----- App -----
APP_NAME=Sistema Integral de Gestión de Reintegros ART
APP_VERSION=0.1.0
DEBUG=true

# ----- Base de datos -----
# SQLite (default, archivo local):
DATABASE_URL=sqlite:///./reintegros.db
# PostgreSQL (cuando migres):
# DATABASE_URL=postgresql://usuario:password@localhost:5432/reintegros

# ----- Seguridad -----
# IMPORTANTE: cambiar en producción por un string aleatorio largo (>32 chars)
# podés generar uno con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-A-LONG-RANDOM-STRING
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ----- CORS -----
# Lista separada por coma o JSON. Default cubre Vite (5173) y CRA (3000) en local.
# CORS_ORIGINS=["http://localhost:5173","https://reintegros.tu-dominio.com.ar"]

# ----- Uploads -----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ----- OCR / PDF -----
OCR_ENABLED=true
OCR_LANGUAGE=spa

# ----- IA (extracción asistida, opcional) -----
AI_EXTRACTION_ENABLED=false
ANTHROPIC_API_KEY=

# ----- SLA -----
SLA_DEFAULT_DAYS=5
SLA_WARNING_HOURS=48
